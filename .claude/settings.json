{
  "permissions": {
    "allow": [
      "Bash(bundle exec rubocop *)",
      "Bash(bundle exec brakeman)",
      "Bash(bundle exec minitest)",
      "Bash(bundle install)",
      "Bash(bin/rails db:migrate*)",
      "Bash(bin/rails db:seed)",
      "Bash(bin/rails generate *)",
      "Bash(bin/rails test)",
      "Bash(bin/rails help *)"
    ],
    "deny": [
      "Bash(rails *)", // force bin/rails
      "Bash(bin/rails db:drop)", // force bin/rails
      "Bash(bundle exec guard)", // No watch mode
      "Bash(guard)"
    ],
    "ask": [
      "Bash(bin/rails server)",
      "Bash(bin/dev)",
      "Bash(bin/rails console)",
      "Bash(bin/rails db:reset)"
    ]
  }
}
