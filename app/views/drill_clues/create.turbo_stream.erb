<%= turbo_stream.update "drill_toast" do %>
  <% if @previous_drill_clue.correct? %>
    <div class="bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg text-center font-semibold text-lg"
         data-controller="auto-dismiss">
      Correct!
    </div>
  <% elsif @previous_drill_clue.incorrect? %>
    <div class="bg-red-500 text-white px-6 py-3 rounded-lg shadow-lg text-center font-semibold text-lg"
         data-controller="auto-dismiss">
      Incorrect &mdash; <%= @previous_drill_clue.correct_response %>
    </div>
  <% else %>
    <div class="bg-gray-500 text-white px-6 py-3 rounded-lg shadow-lg text-center font-semibold text-lg"
         data-controller="auto-dismiss">
      Passed &mdash; <%= @previous_drill_clue.correct_response %>
    </div>
  <% end %>
<% end %>
<%= turbo_stream.replace "drill_clue_frame" do %>
  <%= turbo_frame_tag "drill_clue_frame" do %>
    <%= render "drills/clue_form",
               drill: @drill,
               clue: @clue,
               drill_clue: @drill_clue %>
  <% end %>
<% end %>
<%= turbo_stream.update "drill_stats" do %>
  <div class="bg-white rounded-lg shadow p-4 flex gap-4 text-sm">
    <div class="text-center">
      <div class="font-bold text-green-600"><%= @drill.correct_count %></div>
      <div class="text-gray-600">Correct</div>
    </div>
    <div class="text-center">
      <div class="font-bold text-red-600"><%= @drill.incorrect_count %></div>
      <div class="text-gray-600">Incorrect</div>
    </div>
    <div class="text-center">
      <div class="font-bold text-gray-600"><%= @drill.pass_count %></div>
      <div class="text-gray-600">Passed</div>
    </div>
    <div class="text-center">
      <div class="font-bold text-blue-600"><%= @drill.clues_seen_count %></div>
      <div class="text-gray-600">Seen</div>
    </div>
  </div>
<% end %>
